{
  "name": "blastwave-import-mediawiki",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "wiki": "tsx cli.ts",
    "wiki:import": "tsx cli.ts import markdown --source=tgstation13",
    "wiki:import:dry-run": "tsx cli.ts import markdown --source=tgstation13 --dry-run",
    "wiki:import-html": "tsx cli.ts import html --source=novasector13",
    "wiki:import-html:dry-run": "tsx cli.ts import html --source=novasector13 --dry-run",
    "wiki:import-local": "tsx cli.ts import local",
    "wiki:import-local:engineering": "tsx cli.ts import local --only=guide-to-engineering",
    "wiki:import-local:engineering:dry-run": "tsx cli.ts import local --only=guide-to-engineering --dry-run",
    "wiki:scrape-images": "tsx cli.ts images scrape --source=novasector13",
    "wiki:scrape-images:dry-run": "tsx cli.ts images scrape --source=novasector13 --dry-run",
    "wiki:reimport": "tsx cli.ts reimport --source=novasector13",
    "wiki:reimport:dry-run": "tsx cli.ts reimport --source=novasector13 --dry-run",
    "wiki:fix-links": "tsx cli.ts fix links",
    "wiki:fix-links:dry-run": "tsx cli.ts fix links --dry-run",
    "wiki:update-descriptions": "tsx cli.ts fix descriptions",
    "wiki:update-descriptions:dry-run": "tsx cli.ts fix descriptions --dry-run",
    "wiki:deploy-theme": "tsx cli.ts deploy theme",
    "wiki:setup-player": "tsx cli.ts groups setup-player",
    "wiki:setup-player:dry-run": "tsx cli.ts groups setup-player --dry-run"
  },
  "dependencies": {
    "turndown": "^7.2.0"
  },
  "devDependencies": {
    "@types/node": "^24.12.3",
    "@types/turndown": "^5.0.5",
    "tsx": "^4.19.3",
    "typescript": "~6.0.2"
  }
}
